# YouTube Research Pipeline — Environment Variables

# Notion API (--notion-upload 또는 daily_runner 사용 시 필요)
# NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 중첩 페이지 구조용 (daily_runner에서 사용)
# 일별 부모 페이지가 생성될 상위 페이지 ID
# NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API (--summarize 사용 시 필요)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Language priority for transcript extraction (comma-separated)
# TRANSCRIPT_LANG_PRIORITY=ko,en

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
